# Environment (TypeORM logging is disabled in production)
NODE_ENV='development'

# Database credentials
DB_HOST='localhost'
DB_PORT=5432
DB_USER='postgres'
DB_PASSWORD='postgres'
DB_NAME='wallet_transaction'
DB_SSL='false'

# Server port
PORT=8000

# 64-character hex string used to encrypt/decrypt merchant API keys
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_SECRET='your_64_char_hex_secret_here'

# Seconds within which identical (customer + amount) transactions are flagged as duplicates (default: 15)
DUPLICATE_WINDOW_SECS=15